# OpenSky Network API credentials (OAuth2 client-credentials flow).
# Create an API client at https://opensky-network.org (Account → API client),
# then copy this file to .env.local and fill in the values.
#
# Optional: without credentials the app uses OpenSky's anonymous tier,
# which has a much smaller daily request budget (~400 credits/day).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Set to 1 to always serve synthetic demo traffic instead of calling OpenSky
# (useful for offline development or when the daily quota is exhausted).
# When unset, the app uses OpenSky and only falls back to demo data on error.
OPENSKY_USE_MOCK=
